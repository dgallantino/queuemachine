# Copy to .env and adjust values before: docker compose up --build

QUEUE_MACHINE_SECRET_KEY=change-me-to-a-long-random-string
QUEUE_MACHINE_DEBUG=False
QUEUE_MACHINE_ALLOWED_HOSTS=localhost,127.0.0.1

QUEUE_MACHINE_DB_NAME=queuemachine
QUEUE_MACHINE_DB_USER=queuemachine
QUEUE_MACHINE_DB_PASSWORD=changeme
QUEUE_MACHINE_DB_ROOT_PASSWORD=rootchangeme
QUEUE_MACHINE_DB_HOST=db
QUEUE_MACHINE_DB_PORT=3306

# Host port mapped to nginx
QUEUE_MACHINE_HTTP_PORT=8080
