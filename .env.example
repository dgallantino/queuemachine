# Copy to .env and replace placeholders before running the app.
#
# Local dev (manage.py default): SQLite via queue_machine.settings_dev — DB_* vars are ignored.
# Docker / production: set DJANGO_SETTINGS_MODULE=queue_machine.settings and configure MySQL below.

# Django settings module (<settings-module>)
# Local: queue_machine.settings_dev   Production / Docker: queue_machine.settings
DJANGO_SETTINGS_MODULE=<settings-module>

# Long random string used to sign sessions and cookies (<django-secret-key>)
QUEUE_MACHINE_SECRET_KEY=<django-secret-key>

# Enable Django debug mode (<true-or-false>)
QUEUE_MACHINE_DEBUG=<true-or-false>

# Comma-separated hostnames and IPs allowed to serve the app (<host1,host2>)
QUEUE_MACHINE_ALLOWED_HOSTS=<host1,host2>

# MySQL database name (<database-name>)
QUEUE_MACHINE_DB_NAME=<database-name>

# MySQL application user (<database-user>)
QUEUE_MACHINE_DB_USER=<database-user>

# MySQL application user password (<database-password>)
QUEUE_MACHINE_DB_PASSWORD=<database-password>

# MySQL root password — used by Docker Compose db service only (<database-root-password>)
QUEUE_MACHINE_DB_ROOT_PASSWORD=<database-root-password>

# MySQL host (<database-host>)
# Local MySQL: 127.0.0.1   Docker Compose: db
QUEUE_MACHINE_DB_HOST=<database-host>

# MySQL port (<database-port>)
QUEUE_MACHINE_DB_PORT=<database-port>

# Host port mapped to nginx in Docker Compose (<http-port>)
QUEUE_MACHINE_HTTP_PORT=<http-port>
