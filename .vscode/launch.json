{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Django: runserver (settings_dev)",
            "type": "debugpy",
            "request": "launch",
            "python": "${command:python.interpreterPath}",
            "program": "${workspaceFolder}/manage.py",
            "args": [
                "runserver",
                "0.0.0.0:8000"
            ],
            "django": true,
            "env": {
                "DJANGO_SETTINGS_MODULE": "queue_machine.settings_dev"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Django: tests (settings_test)",
            "type": "debugpy",
            "request": "launch",
            "python": "${command:python.interpreterPath}",
            "program": "${workspaceFolder}/manage.py",
            "args": [
                "test",
                "queue_app.tests"
            ],
            "django": true,
            "env": {
                "DJANGO_SETTINGS_MODULE": "queue_machine.settings_test"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
